{
  "Bridge": {
    "Host": "127.0.0.1",
    "Port": 6721,
    "ApiKey": "change-this-local-key"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ChaosForge": {
    "Mappings": [
      {
        "Id": "development-spawn-common",
        "Enabled": true,
        "Source": "Development",
        "InteractionType": "Command",
        "TriggerName": "SpawnCommonInfected",
        "EventType": "SpawnCommonInfected",
        "CountMultiplier": 1,
        "Parameters": {}
      },
      {
        "Id": "development-spawn-special",
        "Enabled": true,
        "Source": "Development",
        "InteractionType": "Command",
        "TriggerName": "SpawnSpecialInfected",
        "EventType": "SpawnSpecialInfected",
        "CountMultiplier": 1,
        "Parameters": {}
      }
    ]
  },

  "AllowedHosts": "*"
}